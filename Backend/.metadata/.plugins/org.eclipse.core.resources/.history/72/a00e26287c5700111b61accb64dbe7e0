server:
  port: 8080

spring:
  application:
    name: parking-backend

  datasource:
    url: jdbc:postgresql://localhost:5432/ParKing
    username: postgres
    password: jorgealpidio1442

  jpa:
    hibernate:
      ddl-auto: none
    show-sql: true
    properties:
      hibernate:
        format_sql: true
        globally_quoted_identifiers: true

  sql:
    init:
      mode: always

  data:
    redis:
      host: localhost
      port: 6379

logging:
  level:
    com.parking: DEBUG
    org.hibernate.SQL: DEBUG

management:
  endpoints:
    web:
      exposure:
        include: '*'

springdoc:
  swagger-ui:
    path: /swagger-ui.html