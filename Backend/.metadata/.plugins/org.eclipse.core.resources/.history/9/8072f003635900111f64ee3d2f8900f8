spring:
  application:
    name: parking

  datasource:
    url: jdbc:postgresql://localhost:5432/ParKing
    username: postgres
    password: jorgealpidio1442
    driver-class-name: org.postgresql.Driver

  jpa:
    hibernate:
      ddl-auto: none
    show-sql: true
    properties:
      hibernate:
        format_sql: true
        globally_quoted_identifiers: true

  sql:
    init:
      mode: always

server:
  port: 8080

logging:
  level:
    com.parking: DEBUG
    org.hibernate.SQL: DEBUG

cors:
  allowed-origins: http://localhost:5173

springdoc:
  api-docs:
    path: /api-docs

  swagger-ui:
    path: /swagger-ui.html
    tags-sorter: alpha
    operations-sorter: alpha

management:
  endpoints:
    web:
      exposure:
        include: health,info,metrics,prometheus
      base-path: /actuator

  endpoint:
    health:
      show-details: when-authorized
      probes:
        enabled: true

    metrics:
      enabled: true

    prometheus:
      enabled: true

  info:
    env:
      enabled: true

    build:
      enabled: true

info:
  app:
    name: Sistema de Parqueaderos
    version: 1.0.0
    description: API REST para gestión de parqueaderos
    environment: ${SPRING_PROFILES_ACTIVE:local}