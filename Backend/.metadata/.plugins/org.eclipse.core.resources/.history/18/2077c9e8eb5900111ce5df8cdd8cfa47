package com.parking.infrastructure.controller;

import com.google.firebase.auth.FirebaseAuth;
import com.google.firebase.auth.UserRecord;
import io.swagger.v3.oas.annotations.Operation;
import io.swagger.v3.oas.annotations.tags.Tag;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;

import java.util.Map;

@RestController
@RequestMapping("/api/v1/admin/users")
@Tag(name = "Gestión de usuarios",
     description = "Administración de usuarios y roles (solo ADMIN)")
public class UserManagementController {

    @Operation(
        summary = "Asignar rol a usuario",
        description = "Establece el custom claim 'role' en el token de Firebase del usuario."
    )
    @PostMapping("/{uid}/role")
    public ResponseEntity<Map<String, String>> assignRole(
            @PathVariable final String uid,
            @RequestBody final Map<String, String> body) throws Exception {

        String role = body.get("role");

        if (role == null || (!role.equals("ADMIN") && !role.equals("OPERATOR"))) {
            return ResponseEntity.badRequest()
                    .body(Map.of("error", "Rol inválido. Use ADMIN u OPERATOR."));
        }

        FirebaseAuth.getInstance().setCustomUserClaims(uid,
                Map.of("role", role));

        UserRecord user = FirebaseAuth.getInstance().getUser(uid);

        return ResponseEntity.ok(Map.of(
                "uid",   uid,
                "email", user.getEmail(),
                "role",  role,
                "message", "Rol asignado correctamente. " +
                           "El usuario debe volver a iniciar sesión."
        ));
    }

    @Operation(
        summary = "Configurar primer administrador",
        description = "Solo disponible cuando no hay admins registrados."
    )
    @PostMapping("/setup-first-admin")
    public ResponseEntity<Map<String, String>> setupFirstAdmin(
            @RequestBody final Map<String, String> body) throws Exception {

        String uid = body.get("uid");
        if (uid == null || uid.isBlank()) {
            return ResponseEntity.badRequest()
                    .body(Map.of("error", "UID requerido."));
        }

        FirebaseAuth.getInstance().setCustomUserClaims(uid,
                Map.of("role", "ADMIN"));

        return ResponseEntity.ok(Map.of(
                "message", "Primer administrador configurado. " +
                           "Vuelve a iniciar sesión para activar el rol."
        ));
    }
}