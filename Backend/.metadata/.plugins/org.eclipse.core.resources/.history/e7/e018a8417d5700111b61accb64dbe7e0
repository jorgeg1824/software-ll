spring:
  datasource:
    # Cloud Run se conecta a Cloud SQL por socket Unix, no por host/puerto
    url: jdbc:postgresql:///${DB_NAME}?cloudSqlInstance=${CLOUD_SQL_CONNECTION}&socketFactory=com.google.cloud.sql.postgres.SocketFactory
    username: ${DB_USER}
    password: ${DB_PASSWORD}
    driver-class-name: org.postgresql.Driver

  jpa:
    hibernate:
      ddl-auto: none
    show-sql: false
    properties:
      hibernate:
        globally_quoted_identifiers: true

  sql:
    init:
      mode: never   # En producción no ejecutamos data.sql

server:
  port: 8080