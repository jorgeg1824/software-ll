package com.parking.infrastructure.controller;

import com.parking.crosscuting.exception.BusinessException;
import com.parking.crosscuting.messagescatalog.MessagesEnum;
import com.parking.infrastructure.rest.dto.ErrorResponse;
import jakarta.servlet.http.HttpServletRequest;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.context.MessageSource;
import org.springframework.http.HttpStatus;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.MethodArgumentNotValidException;
import org.springframework.web.bind.annotation.ExceptionHandler;
import org.springframework.web.bind.annotation.RestControllerAdvice;
import org.springframework.web.servlet.LocaleResolver;
import org.springframework.web.servlet.resource.NoResourceFoundException;

import java.util.Locale;

@RestControllerAdvice
public class GlobalExceptionHandler {

    private static final Logger log =
            LoggerFactory.getLogger(GlobalExceptionHandler.class);

    private final MessageSource messageSource;
    private final LocaleResolver localeResolver;

    public GlobalExceptionHandler(final MessageSource messageSource,
                                   final LocaleResolver localeResolver) {
        this.messageSource  = messageSource;
        this.localeResolver = localeResolver;
    }

    @ExceptionHandler(MethodArgumentNotValidException.class)
    public ResponseEntity<ErrorResponse> handleValidationError(
            final MethodArgumentNotValidException ex,
            final HttpServletRequest request) {

        Locale locale = localeResolver.resolveLocale(request);

        String enumKey = ex.getBindingResult().getFieldErrors()
                .stream()
                .findFirst()
                .map(e -> e.getDefaultMessage())
                .orElse(MessagesEnum.GENERAL_UNEXPECTED_ERROR.name());

        return ResponseEntity
                .status(HttpStatus.BAD_REQUEST)
                .body(buildError(enumKey, HttpStatus.BAD_REQUEST, locale));
    }

    @ExceptionHandler(BusinessException.class)
    public ResponseEntity<ErrorResponse> handleBusinessError(
            final BusinessException ex,
            final HttpServletRequest request) {

        Locale locale = localeResolver.resolveLocale(request);
        String key    = ex.getMessagesEnum().name();

        return ResponseEntity
                .status(HttpStatus.CONFLICT)
                .body(buildError(key, HttpStatus.CONFLICT, locale));
    }

    @ExceptionHandler(IllegalArgumentException.class)
    public ResponseEntity<ErrorResponse> handleDomainInvariantError(
            final IllegalArgumentException ex,
            final HttpServletRequest request) {

        Locale locale = localeResolver.resolveLocale(request);

        return ResponseEntity
                .status(HttpStatus.UNPROCESSABLE_ENTITY)
                .body(buildError(ex.getMessage(),
                        HttpStatus.UNPROCESSABLE_ENTITY, locale));
    }

    @ExceptionHandler(NoResourceFoundException.class)
    public ResponseEntity<Void> handleNoResourceFound(
            final NoResourceFoundException ex) {
        return ResponseEntity.notFound().build();
    }

    @ExceptionHandler(Exception.class)
    public ResponseEntity<ErrorResponse> handleUnexpectedError(
            final Exception ex,
            final HttpServletRequest request) {

        log.error("Error inesperado capturado: ", ex);
        Locale locale = localeResolver.resolveLocale(request);

        return ResponseEntity
                .status(HttpStatus.INTERNAL_SERVER_ERROR)
                .body(buildError(
                        MessagesEnum.GENERAL_UNEXPECTED_ERROR.name(),
                        HttpStatus.INTERNAL_SERVER_ERROR,
                        locale));
    }

    private ErrorResponse buildError(final String key,
                                      final HttpStatus status,
                                      final Locale locale) {
        String title  = resolveMessage(key + ".title",  locale,
                        fallbackTitle(key));
        String detail = resolveMessage(key + ".detail", locale,
                        fallbackDetail(key));

        return new ErrorResponse(title, detail, status.value());
    }

    private String resolveMessage(final String key,
                                   final Locale locale,
                                   final String fallback) {
        try {
            String msg = messageSource.getMessage(key, null, locale);
            return (msg == null || msg.equals(key)) ? fallback : msg;
        } catch (Exception e) {
            return fallback;
        }
    }

    private String fallbackTitle(final String key) {
        try {
            return MessagesEnum.valueOf(key).getTitle();
        } catch (Exception e) {
            return MessagesEnum.GENERAL_UNEXPECTED_ERROR.getTitle();
        }
    }

    private String fallbackDetail(final String key) {
        try {
            return MessagesEnum.valueOf(key).getContent();
        } catch (Exception e) {
            return MessagesEnum.GENERAL_UNEXPECTED_ERROR.getContent();
        }
    }
}